#!/bin/bash
set -e

[ ! -t 0 ] && exec 0</dev/tty 2>/dev/null || true

echo ""
echo "  hy-harness · 一键部署 code/doc lint + MCP"
echo "  ─────────────────────────────────────────"
echo ""

if [ -f codelint.json ]; then
  echo "  ⏭  codelint.json 已存在，跳过 codelint deploy"
else
  echo "  ── codelint ──"
  npx github:voxServalG/codelint deploy
fi

echo ""

if [ -f doclint.json ]; then
  echo "  ⏭  doclint.json 已存在，跳过 doclint deploy"
else
  echo "  ── doclint ──"
  npx github:voxServalG/doclint deploy
fi

echo ""

if [ -f docs-gardener.json ]; then
  echo "  ⏭  docs-gardener.json 已存在，跳过 docs-gardener deploy"
else
  echo "  ── pre-filling shared config from doclint.json ──"
  node -e "
    const fs = require('fs');
    if (!fs.existsSync('doclint.json')) {
      console.log('  ⚠ doclint.json not found, using defaults');
      process.exit(0);
    }
    const dl = JSON.parse(fs.readFileSync('doclint.json','utf8'));
    const gardener = {docsDir:dl.docsDir, codeDirs:dl.codeDirs, codeExt:dl.codeExt, baseBranch:dl.baseBranch, catalogs:{}};
    fs.writeFileSync('docs-gardener.json', JSON.stringify(gardener,null,2));
    console.log('  ✓ docs-gardener.json pre-filled');
  "
  echo ""
  echo "  ── docs-gardener ──"
  npx github:voxServalG/docs-gardener deploy
fi

echo ""
echo "  ── 完成 ──"
[ -f codelint.json ]       && echo "  ✓ codelint.json"
[ -f doclint.json ]        && echo "  ✓ doclint.json"
[ -f docs-gardener.json ]  && echo "  ✓ docs-gardener.json"
[ -f .github/workflows/code-quality.yml ] && echo "  ✓ .github/workflows/code-quality.yml"
[ -f .github/workflows/docs-check.yml ]   && echo "  ✓ .github/workflows/docs-check.yml"
echo ""
